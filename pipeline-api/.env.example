# BEMI Pipeline API — environment variable template
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.

# ── API auth (for programmatic / dashboard calls) ──────────────────────────
# Bearer token for all /runs/* API endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PIPELINE_API_KEY=your-secret-api-key-here

# ── Pipeline paths ─────────────────────────────────────────────────────────
# Absolute path to the BEMI enrichment pipeline repo (contains pipeline.py)
PIPELINE_REPO_PATH=/absolute/path/to/BEMI-enrichment-pipeline

# Absolute path where run output directories will be written
# Each run creates: {OUTPUT_RUNS_PATH}/RUN-YYYYMMDD-HHMMSS/
OUTPUT_RUNS_PATH=/absolute/path/to/output/runs

# Python executable used to invoke pipeline.py (default: python3)
PYTHON_EXECUTABLE=python3

# ── Web UI login ───────────────────────────────────────────────────────────
# Single-user mode: set UI_USERNAME and UI_PASSWORD
UI_USERNAME=rajiv
UI_PASSWORD=your-ui-password-here

# Multi-user mode (overrides UI_USERNAME/UI_PASSWORD when set):
# Comma-separated list of username:password pairs
# UI_USERS=rajiv:password1,analyst:password2

# Secret key for signing session cookies — required for production use.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your-session-secret-key-here

# Session lifetime in hours (default: 8)
SESSION_MAX_AGE_HOURS=8

# ── Server ─────────────────────────────────────────────────────────────────
MAX_CSV_SIZE_MB=50
MAX_CSV_ROWS=10000
HOST=0.0.0.0
PORT=8000
