# BEMI Pipeline API — environment variable template
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.

# Required: secret key used to authenticate all API requests (Bearer token)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PIPELINE_API_KEY=your-secret-api-key-here

# Required: absolute path to the BEMI enrichment pipeline repository
# This is the directory containing pipeline.py
PIPELINE_REPO_PATH=/absolute/path/to/BEMI-enrichment-pipeline

# Required: absolute path where run output directories will be written
# Each run creates a subdirectory: {OUTPUT_RUNS_PATH}/RUN-YYYYMMDD-HHMMSS/
OUTPUT_RUNS_PATH=/absolute/path/to/output/runs

# Python executable used to invoke pipeline.py (default: python3)
PYTHON_EXECUTABLE=python3

# Maximum CSV file size accepted (default: 50 MB)
MAX_CSV_SIZE_MB=50

# Maximum number of CSV rows accepted (default: 10000)
MAX_CSV_ROWS=10000

# API server bind address (default: 0.0.0.0)
HOST=0.0.0.0

# API server port (default: 8000)
PORT=8000
