# BEMI Pipeline API — environment variable template
# Copy this file to .env and fill in all values before starting the server.
# Never commit .env to version control.

# ── AI (ICP Builder) ───────────────────────────────────────────────────────
# Required only for the AI-assisted ICP Profile Builder at /icp-profiles/new.
# Leave blank to disable AI generation (manual entry still works).
ANTHROPIC_API_KEY=sk-ant-...

# ── API auth (for programmatic / dashboard calls) ──────────────────────────
# Bearer token for all /runs/* API endpoints.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PIPELINE_API_KEY=your-secret-api-key-here

# ── Pipeline paths ─────────────────────────────────────────────────────────
# Absolute path to the BEMI enrichment pipeline repo (contains pipeline.py)
PIPELINE_REPO_PATH=/absolute/path/to/BEMI-enrichment-pipeline

# Absolute path where run output directories will be written
# Each run creates: {OUTPUT_RUNS_PATH}/RUN-YYYYMMDD-HHMMSS/
OUTPUT_RUNS_PATH=/absolute/path/to/output/runs

# Project configs and ICP profiles. Default to siblings of OUTPUT_RUNS_PATH
# (i.e. {output}/projects and {output}/icp_profiles). Override only if you keep
# them elsewhere.
# PROJECTS_PATH=/absolute/path/to/output/projects
# ICP_PROFILES_PATH=/absolute/path/to/output/icp_profiles

# Python executable used to invoke pipeline.py.
# Leave this UNSET (or commented out) to use the same Python that runs the
# server — this guarantees the pipeline subprocess has Playwright/Chromium for
# browser re-crawl. Only set it if you deliberately want a different interpreter.
# PYTHON_EXECUTABLE=python3

# ── Web UI login ───────────────────────────────────────────────────────────
# Single-user mode: set UI_USERNAME and UI_PASSWORD
UI_USERNAME=rajiv
UI_PASSWORD=your-ui-password-here

# Multi-user mode (overrides UI_USERNAME/UI_PASSWORD when set):
# Comma-separated list of username:password pairs
# UI_USERS=rajiv:password1,analyst:password2

# Secret key for signing session cookies — required for production use.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=your-session-secret-key-here

# Session lifetime in hours (default: 8)
SESSION_MAX_AGE_HOURS=8

# ── Server ─────────────────────────────────────────────────────────────────
MAX_CSV_SIZE_MB=50
MAX_CSV_ROWS=10000
# Max simultaneous pipeline runs (guards host resources)
MAX_CONCURRENT_RUNS=3
HOST=0.0.0.0
PORT=8000
