# Bullseye Enrichment Pipeline — Environment Variables
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to git.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model IDs.
# Pin these to EXPLICIT dated snapshots (not floating aliases) so a vendor model
# update cannot silently change extraction quality. Upgrade intentionally: change
# the snapshot, then run `python eval_signals.py --live --check` before shipping.
# The values below are the current floating defaults — replace each with the dated
# snapshot you validated (e.g. CLAUDE_MODEL=claude-sonnet-4-6-YYYYMMDD).
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-5.5
