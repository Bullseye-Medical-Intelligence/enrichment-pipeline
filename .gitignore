# Environment
.env
*.env

# Output files — never commit real client data
/output/*.json
/output/*.csv
/output/icp_profiles/
/output/runs/
/output/projects/

# Published client sales-handoff briefs mirrored from Hostinger (RULE 2):
# generated client deliverables, not hand-edited marketing pages.
/site/briefs/

# Runtime directories that appear when server CWD is repo root
/icp_profiles/
/runs/
/projects/

# Discovery — runtime registry and temp session files (operator data, not source)
/master_practice_registry.json
/output/discovery/

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.eggs/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code session data
.claude/

# macOS
.DS_Store

# Data directory — raw input CSVs may contain client data
/data/*.csv

# Generated renderer output (sample_run.py artifact)
sample_output.html

# Golden eval fixtures scaffolded from real runs are input lists + crawled page
# text + enriched records — keep them out of git (RULE 2). The two synthetic demo
# cases (cedar_park, lone_star) are the tracked exception.
/evals/golden/*/
!/evals/golden/cedar_park/
!/evals/golden/lone_star/
